{
  "name": "@chromvoid/headless-ui",
  "version": "0.0.1",
  "description": "Headless interaction and accessibility contracts for future UI kit",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md",
    "specs"
  ],
  "scripts": {
    "lint": "npm run lint:types && npm run lint:oxlint && npm run lint:prettier && npm run lint:boundaries",
    "lint:types": "tsc --noEmit -p tsconfig.json",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json \"src/**/*.{ts,tsx}\"",
    "lint:prettier": "prettier --check --config ../../.prettierrc.cjs \"src/**/*.{ts,tsx}\" \"README.md\" \"specs/**/*.md\" \"*.json\"",
    "lint:boundaries": "node ./scripts/check-standalone-boundaries.mjs",
    "lint:release-governance": "node ./scripts/check-release-governance.mjs",
    "format": "prettier --write --config ../../.prettierrc.cjs \"src/**/*.{ts,tsx}\" \"README.md\" \"specs/**/*.md\" \"*.json\"",
    "test": "vitest run --config ./vitest.config.ts",
    "test:unit": "vitest --config ./vitest.config.ts --watch",
    "release:changelog": "node ./scripts/generate-changelog.mjs --mode full --out ./specs/release/changelog.generated.md && npx prettier --write ./specs/release/changelog.generated.md",
    "release:changelog:patch": "node ./scripts/generate-changelog.mjs --mode patch --out ./specs/release/changelog.patch.generated.md && npx prettier --write ./specs/release/changelog.patch.generated.md"
  },
  "keywords": [
    "headless",
    "a11y",
    "apg",
    "reatom"
  ],
  "author": "ChromVoid Team",
  "license": "MIT",
  "dependencies": {
    "@reatom/core": "^1000.15.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
